---
const { job } = Astro.props;

const locationTypeLabels = {
  onsite: 'On-site',
  remote: 'Remote',
  hybrid: 'Hybrid'
};

const employmentTypeLabels = {
  'full-time': 'Full-time',
  'part-time': 'Part-time',
  contract: 'Contract',
  internship: 'Internship'
};

function formatSalary(min, max, currency) {
  if (!min && !max) return null;
  const fmt = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: currency || 'USD',
    maximumFractionDigits: 0
  });
  if (min && max) return `${fmt.format(min)} - ${fmt.format(max)}`;
  if (min) return `From ${fmt.format(min)}`;
  return `Up to ${fmt.format(max)}`;
}

const salary = formatSalary(job.salaryMin, job.salaryMax, job.salaryCurrency);
---

<div class="job-excerpt">
  <div class="job-excerpt-header">
    <h3 class="job-excerpt-title">
      <a href={job._url}>{job.title}</a>
    </h3>
    {!job._url && (
      <p class="meta"><em>Job board page required</em></p>
    )}
  </div>
  <div class="job-excerpt-details">
    {job.team && <span class="job-detail job-detail--team">{job.team}</span>}
    {job.location && <span class="job-detail job-detail--location">{job.location}</span>}
    {job.locationType && <span class="job-detail">{locationTypeLabels[job.locationType] || job.locationType}</span>}
    {job.employmentType && <span class="job-detail">{employmentTypeLabels[job.employmentType] || job.employmentType}</span>}
    {salary && <span class="job-detail job-detail--salary">{salary}</span>}
  </div>
</div>

<style>
  .job-excerpt {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .job-excerpt:hover {
    border-color: var(--a-primary, #6236ff);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .job-excerpt-title {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
  }
  .job-excerpt-title a {
    text-decoration: none;
    color: inherit;
  }
  .job-excerpt-title a:hover {
    color: var(--a-primary, #6236ff);
  }
  .job-excerpt-details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .job-detail {
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    background: #f3f4f6;
    color: #555;
  }
  .job-detail--team {
    background: #e8f0fe;
    color: #1a73e8;
  }
  .job-detail--location {
    background: #e6f4ea;
    color: #137333;
  }
  .job-detail--salary {
    background: #fef7e0;
    color: #b06000;
  }
</style>
