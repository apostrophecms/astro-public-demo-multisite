---
import {
  getAttachmentUrl,
  getAttachmentSrcset,
  getWidth,
  getHeight
} from '@apostrophecms/apostrophe-astro/lib/attachment.js';

const { room, layout = 'grid' } = Astro.props;

const roomTypeLabels = {
  standard: 'Standard',
  deluxe: 'Deluxe',
  'junior-suite': 'Junior Suite',
  suite: 'Suite',
  'executive-suite': 'Executive Suite',
  penthouse: 'Penthouse',
  villa: 'Villa',
  studio: 'Studio'
};

const bedLabels = {
  king: 'King bed',
  queen: 'Queen bed',
  'two-queens': 'Two queen beds',
  'two-doubles': 'Two double beds',
  'two-twins': 'Two twin beds',
  'king-sofa': 'King + sofa bed',
  bunk: 'Bunk bed'
};

const viewLabels = {
  ocean: 'Ocean View',
  pool: 'Pool View',
  garden: 'Garden View',
  city: 'City Skyline',
  courtyard: 'Courtyard',
  mountain: 'Mountain View',
  interior: 'Interior'
};

function formatRate(amount, currency) {
  if (!amount) return null;
  const fmt = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: currency || 'USD',
    maximumFractionDigits: 0
  });
  return fmt.format(amount);
}

const rate = formatRate(room.nightlyRate, room.rateCurrency);

const imageObj = room?._featuredImage?.[0];
const imageUrl = imageObj ? getAttachmentUrl(imageObj, { size: 'one-half' }) : null;
const imageSrcset = imageObj ? getAttachmentSrcset(imageObj) : null;
const imageWidth = imageObj ? getWidth(imageObj) : undefined;
const imageHeight = imageObj ? getHeight(imageObj) : undefined;
---

<div class={`room-excerpt room-excerpt--${layout}`}>
  {layout === 'grid' && imageUrl && (
    <a class="room-excerpt__image" href={room._url}>
      <img
        loading="lazy"
        src={imageUrl}
        alt={imageObj?.title || room.title}
        width={imageWidth}
        height={imageHeight}
        srcset={imageSrcset}
      />
    </a>
  )}
  <div class="room-excerpt__body">
    <div class="room-excerpt__header">
      <h3 class="room-excerpt__title">
        <a href={room._url}>{room.title}</a>
      </h3>
      {!room._url && (
        <p class="meta"><em>Rooms page required</em></p>
      )}
    </div>
    <div class="room-excerpt__details">
      {room.roomType && <span class="room-detail room-detail--type">{roomTypeLabels[room.roomType] || room.roomType}</span>}
      {room.view && <span class="room-detail room-detail--view">{viewLabels[room.view] || room.view}</span>}
      {room.bedConfiguration && <span class="room-detail">{bedLabels[room.bedConfiguration] || room.bedConfiguration}</span>}
      {room.maxOccupancy && <span class="room-detail">Sleeps {room.maxOccupancy}</span>}
      {room.squareFeet && <span class="room-detail">{room.squareFeet} sq ft</span>}
    </div>
    {rate && (
      <div class="room-excerpt__rate">
        <span class="room-excerpt__rate-from">From</span>
        <span class="room-excerpt__rate-amount">{rate}</span>
        <span class="room-excerpt__rate-unit">/ night</span>
      </div>
    )}
  </div>
</div>

<style>
  .room-excerpt {
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
    background: var(--surface-color);
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }
  .room-excerpt:hover {
    border-color: var(--a-primary, #6236ff);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .room-excerpt--grid {
    display: flex;
    flex-direction: column;
  }
  .room-excerpt--list {
    padding: 1.25rem 1.5rem;
  }
  .room-excerpt__image {
    display: block;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f3f4f6;
  }
  .room-excerpt__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .room-excerpt:hover .room-excerpt__image img {
    transform: scale(1.04);
  }
  .room-excerpt__body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .room-excerpt--list .room-excerpt__body { padding: 0; }
  .room-excerpt__title {
    margin: 0;
    font-size: 1.2rem;
  }
  .room-excerpt__title a {
    text-decoration: none;
    color: inherit;
  }
  .room-excerpt__title a:hover {
    color: var(--a-primary, #6236ff);
  }
  .room-excerpt__details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .room-detail {
    font-size: 0.78rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: #f3f4f6;
    color: #4b5563;
  }
  .room-detail--type {
    background: #eef2ff;
    color: #4338ca;
    font-weight: 600;
  }
  .room-detail--view {
    background: #ecfdf5;
    color: #047857;
  }
  .room-excerpt__rate {
    margin-top: auto;
    padding-top: 0.25rem;
    color: #111827;
  }
  .room-excerpt__rate-from {
    color: #6b7280;
    font-size: 0.85rem;
    margin-right: 0.3rem;
  }
  .room-excerpt__rate-amount {
    font-size: 1.2rem;
    font-weight: 700;
  }
  .room-excerpt__rate-unit {
    color: #6b7280;
    font-size: 0.85rem;
    margin-left: 0.1rem;
  }
</style>
