---
import AposArea from '@apostrophecms/apostrophe-astro/components/AposArea.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import JobResults from '../components/JobResults.astro';

const {
  page,
  pieces = [],
  piecesFilters = {},
  currentPage = 1,
  totalPages = 1,
  url: aposUrl,
  global
} = Astro.props.aposData;

const pageUrl = aposUrl || page?._url || Astro.url.pathname;
const companyName = global?.companyName || global?.siteTitle || '';
const searchParams = Astro.url.searchParams;
---

<Breadcrumbs {page} />

<div class="job-title-wrapper">
  <div class="layout">
    <h1 class="page-title">{page.title}</h1>
    {companyName && <p class="job-company-subtitle">Open positions at {companyName}</p>}
  </div>
</div>

<div class="layout">
  <div class="job-columns">
    <main class="job-index">
      {page.aboveJobs && <AposArea area={page.aboveJobs} />}

      <JobResults
        {pieces}
        {piecesFilters}
        {currentPage}
        {totalPages}
        {pageUrl}
        {searchParams}
      />

      {page.belowJobs && <AposArea area={page.belowJobs} />}
    </main>
    {page.sidebar && (
      <aside class="job-sidebar">
        <AposArea area={page.sidebar} />
      </aside>
    )}
  </div>
</div>

<style>
  .job-title-wrapper {
    padding: 2rem 0 1rem;
  }
  .job-company-subtitle {
    color: #666;
    font-size: 1.1rem;
    margin-top: 0.25rem;
  }
</style>
