---
import AposArea from '@apostrophecms/apostrophe-astro/components/AposArea.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const { page, piece, global } = Astro.props.aposData;
const job = piece;
const companyName = global?.companyName || global?.siteTitle || '';

function formatSalary(min, max, currency) {
  if (!min && !max) return null;
  const fmt = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: currency || 'USD',
    maximumFractionDigits: 0
  });
  if (min && max) return `${fmt.format(min)} - ${fmt.format(max)}`;
  if (min) return `From ${fmt.format(min)}`;
  return `Up to ${fmt.format(max)}`;
}

const salary = formatSalary(job.salaryMin, job.salaryMax, job.salaryCurrency);

const locationTypeLabels = {
  onsite: 'On-site',
  remote: 'Remote',
  hybrid: 'Hybrid'
};

const employmentTypeLabels = {
  'full-time': 'Full-time',
  'part-time': 'Part-time',
  contract: 'Contract',
  internship: 'Internship'
};

const experienceLevelLabels = {
  entry: 'Entry Level',
  mid: 'Mid Level',
  senior: 'Senior',
  lead: 'Lead',
  executive: 'Executive'
};
---

<Breadcrumbs {page} {piece} />

<div class="job-title-wrapper">
  <div class="layout">
    <h1 class="page-title">{job.title}</h1>
    {companyName && <p class="job-company">{companyName}</p>}
  </div>
</div>

<div class="layout">
  <main>
    <article class="job-show">
      <div class="job-meta">
        {job.team && (
          <span class="job-tag job-tag--team">{job.team}</span>
        )}
        {job.location && (
          <span class="job-tag job-tag--location">{job.location}</span>
        )}
        {job.locationType && (
          <span class="job-tag job-tag--location-type">{locationTypeLabels[job.locationType] || job.locationType}</span>
        )}
        {job.employmentType && (
          <span class="job-tag job-tag--employment">{employmentTypeLabels[job.employmentType] || job.employmentType}</span>
        )}
        {job.experienceLevel && (
          <span class="job-tag job-tag--experience">{experienceLevelLabels[job.experienceLevel] || job.experienceLevel}</span>
        )}
        {salary && (
          <span class="job-tag job-tag--salary">{salary}</span>
        )}
      </div>

      <div class="job-description general-content">
        <AposArea area={job.description} />
      </div>
    </article>
  </main>
</div>

<style>
  .job-title-wrapper {
    padding: 2rem 0 1rem;
  }
  .job-company {
    color: #666;
    font-size: 1.1rem;
    margin-top: 0.25rem;
  }
  .job-show {
    padding-bottom: 3rem;
  }
  .job-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .job-tag {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    background: #f0f0f0;
    color: #444;
  }
  .job-tag--team {
    background: #e8f0fe;
    color: #1a73e8;
  }
  .job-tag--location {
    background: #e6f4ea;
    color: #137333;
  }
  .job-tag--salary {
    background: #fef7e0;
    color: #b06000;
  }
  .job-description {
    max-width: 800px;
  }
</style>
