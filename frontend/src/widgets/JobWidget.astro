---
import JobExcerpt from '../components/JobExcerpt.astro';

const { widget } = Astro.props;
const limit = widget.limit || 5;

let jobs = [];
try {
  const aposHost = import.meta.env.APOS_HOST || process.env.APOS_HOST || 'http://localhost:3000';
  const response = await fetch(
    `${aposHost}/api/v1/job?perPage=${limit}&sort[createdAt]=-1`
  );

  if (response.ok) {
    const data = await response.json();
    jobs = data.results || [];
  } else {
    console.error('Job API response:', response.status, response.statusText);
  }
} catch (error) {
  console.error('Failed to fetch jobs:', error);
}
---

<div class="widget job-widget">
  <h3 class="job-widget-title">Open Positions</h3>
  {jobs.length > 0 ? (
    <div class="job-widget-list">
      {jobs.map((job) => (
        <JobExcerpt job={job} />
      ))}
    </div>
  ) : (
    <p class="no-jobs">No open positions at this time.</p>
  )}
</div>

<style>
  .job-widget-title {
    margin-bottom: 1rem;
    font-size: 1.3rem;
  }
  .job-widget-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .no-jobs {
    text-align: center;
    padding: 2rem;
    color: #666;
    font-style: italic;
  }
</style>
